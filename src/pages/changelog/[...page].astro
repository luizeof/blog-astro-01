---
// Components
// - Layout
import Layout from '../../layouts/Layout.astro'
// - UI
import Hero from '../../components/blocks/hero/PageHeader.astro'
import SimpleFeed from '../../components/blocks/feeds/BasicFeed.astro'
import CTA from '../../components/blocks/CTA/BasicLight.astro'
import Pagination from '../../components/ui/blog/Pagination.astro'

// Data
import feedData from '../../data/json-files/changelogData.json'
import { configData } from '../../config/config'
import type { Page } from 'astro'

export async function getStaticPaths({ paginate }: any) {
	// Sort changelog data by date (if not already sorted)
	const sortedData = feedData.sort((a, b) => {
		return new Date(b.date).getTime() - new Date(a.date).getTime()
	})

	return paginate(sortedData, { pageSize: configData.changelogPerPage || 10 })
}

const { page } = Astro.props as { page: Page<any> }

// Content
// - SEO
const SEO = {
	title: page.currentPage === 1 ? 'Changelog | Promovaweb' : `Changelog | Página ${page.currentPage} | Promovaweb`,
	description:
		"Stay informed about all the new updates and improvements in Promovaweb. Explore Promovaweb's powerful features designed to enhance productivity."
}
// - Page Header
const header = {
	title: 'Promovaweb Version Updates and <strong>Enhancements</strong>',
	text: 'Stay informed about all the new updates and improvements in Promovaweb.'
}
---

<Layout title={SEO.title} description={SEO.description}>
	<Hero title={header.title} text={header.text} />
	<SimpleFeed data={page.data} />
	<Pagination page={page} />
	<CTA />
</Layout>
