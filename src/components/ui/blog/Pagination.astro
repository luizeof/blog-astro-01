---
// Pagination
// ------------
// Description: The pagination component for the blog.
// Properties:
// - page: The page object from Astro's paginate function

const { page } = Astro.props;
---

<nav class="flex items-center justify-center space-x-2 my-12" aria-label="Pagination">
  {page.url.prev ? (
    <a
      href={page.url.prev}
      class="inline-flex items-center rounded-lg border border-neutral-100 px-4 py-2 text-sm font-medium text-neutral-500 hover:bg-neutral-50 dark:border-neutral-800 dark:text-neutral-400 dark:hover:bg-neutral-800"
    >
      <svg class="mr-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      Anterior
    </a>
  ) : (
    <span class="inline-flex items-center rounded-lg border border-neutral-50 px-4 py-2 text-sm font-medium text-neutral-300 cursor-not-allowed dark:border-neutral-900 dark:text-neutral-700">
      <svg class="mr-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      Anterior
    </span>
  )}

  <div class="flex items-center space-x-1">
    <span class="text-sm font-medium text-neutral-500 dark:text-neutral-400">
      Página <span class="text-primary-500">{page.currentPage}</span> de {page.lastPage}
    </span>
  </div>

  {page.url.next ? (
    <a
      href={page.url.next}
      class="inline-flex items-center rounded-lg border border-neutral-100 px-4 py-2 text-sm font-medium text-neutral-500 hover:bg-neutral-50 dark:border-neutral-800 dark:text-neutral-400 dark:hover:bg-neutral-800"
    >
      Próximo
      <svg class="ml-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
    </a>
  ) : (
    <span class="inline-flex items-center rounded-lg border border-neutral-50 px-4 py-2 text-sm font-medium text-neutral-300 cursor-not-allowed dark:border-neutral-900 dark:text-neutral-700">
      Próximo
      <svg class="ml-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
    </span>
  )}
</nav>
